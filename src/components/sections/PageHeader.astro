---
// Reusable page header component to eliminate redundancy
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  gradient?: 'blue' | 'purple' | 'multi';
}

const { title, subtitle, description, gradient = 'blue' } = Astro.props;

const gradientClasses = {
  blue: 'from-blue-50 to-purple-50 dark:from-slate-950 dark:to-slate-900',
  purple: 'from-purple-50 to-pink-50 dark:from-slate-950 dark:to-purple-950',
  multi: 'from-blue-50 via-white to-purple-50 dark:from-slate-950 dark:via-slate-900 dark:to-purple-950',
};
---

<section class={`py-20 px-4 bg-gradient-to-br ${gradientClasses[gradient]}`}>
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">
      <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        {title}
      </span>
    </h1>
    {subtitle && (
      <h2 class="text-xl sm:text-2xl md:text-3xl text-slate-600 dark:text-slate-300 mb-4 font-light">
        {subtitle}
      </h2>
    )}
    {description && (
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {description}
      </p>
    )}
  </div>
</section>
