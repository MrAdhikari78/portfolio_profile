---
import MainLayout from '../layouts/MainLayout.astro';
import AnimatedGradient from '../components/sections/AnimatedGradient.astro';
---

<MainLayout title="Home - Manish's Portfolio" description="Welcome to my portfolio">
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center px-4 py-20 relative overflow-hidden gradient-bg-multi">
    <AnimatedGradient />

    <div class="max-w-4xl mx-auto text-center z-10">
      <!-- Animated greeting -->
      <div class="inline-block mb-6 px-4 py-2 rounded-full bg-blue-100/80 dark:bg-blue-900/30 backdrop-blur border border-blue-200 dark:border-blue-800">
        <p class="text-sm font-semibold text-blue-700 dark:text-blue-300">Welcome to my digital space 👋</p>
      </div>

      <!-- Main heading -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold mb-6 leading-tight text-gradient-alt">
        Manish Adhikari
      </h1>

      <!-- Subtitle with typing effect illusion -->
      <h2 class="text-xl sm:text-2xl md:text-3xl text-slate-600 dark:text-slate-300 mb-8 font-light">
        Full Stack Developer & Creative Problem Solver
      </h2>

      <!-- Description -->
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
        I build beautiful, performant web applications with modern technologies. Passionate about clean code, user experience, and bringing ideas to life.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a href="/projects" class="btn-primary">
          View My Work
        </a>
        <a href="#contact" class="btn-secondary">
          Get In Touch
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="flex justify-center animate-bounce">
        <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 px-4 max-w-4xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- About Text -->
      <div>
        <h2 class="text-4xl font-bold mb-6">About Me</h2>
        <p class="text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
          Hi! I'm a passionate full-stack developer with over 3 years of experience building web applications. I love turning complex problems into simple, beautiful, and intuitive designs.
        </p>
        <p class="text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
          When I'm not coding, you can find me exploring new technologies, contributing to open-source projects, or sharing knowledge with the community.
        </p>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
          I'm currently open to freelance projects and full-time opportunities that challenge me to grow and create meaningful impact.
        </p>
      </div>

      <!-- Skills Grid -->
      <div>
        <h3 class="text-2xl font-bold mb-6">Skills</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 rounded-lg bg-slate-100 dark:bg-slate-800">
            <h4 class="font-semibold mb-2 text-blue-600 dark:text-blue-400">Frontend</h4>
            <p class="text-sm text-slate-600 dark:text-slate-400">React, Vue, Astro, TypeScript</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-100 dark:bg-slate-800">
            <h4 class="font-semibold mb-2 text-purple-600 dark:text-purple-400">Backend</h4>
            <p class="text-sm text-slate-600 dark:text-slate-400">Node.js, Python, PostgreSQL</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-100 dark:bg-slate-800">
            <h4 class="font-semibold mb-2 text-pink-600 dark:text-pink-400">Tools</h4>
            <p class="text-sm text-slate-600 dark:text-slate-400">Git, Docker, AWS, Vercel</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-100 dark:bg-slate-800">
            <h4 class="font-semibold mb-2 text-green-600 dark:text-green-400">Design</h4>
            <p class="text-sm text-slate-600 dark:text-slate-400">Figma, UI/UX, Tailwind CSS</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Preview -->
  <section class="py-20 px-4 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12 text-center">
        <h2 class="text-4xl font-bold mb-4">
          <span class="text-gradient">Featured Projects</span>
        </h2>
        <p class="text-center text-slate-600 dark:text-slate-400">
          A selection of my recent work and side projects
        </p>
      </div>

      <!-- Quick Project Cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="p-6 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">E-Commerce Platform</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Modern shopping experience with React & Node.js</p>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">Task Management App</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Collaborative tool for team productivity</p>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-lg bg-pink-100 dark:bg-pink-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 13h2v8H3zm4-8h2v16H7zm4-2h2v18h-2zm4-2h2v20h-2zm4 4h2v16h-2zm4 8h2v8h-2z"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">Analytics Dashboard</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Real-time data visualization platform</p>
        </div>
      </div>

      <div class="text-center">
        <a href="/projects" class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-colors">
          View All Projects
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }

  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
