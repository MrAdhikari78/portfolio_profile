---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Get related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(post => post.slug !== entry.slug && post.data.tags.some(tag => entry.data.tags.includes(tag)))
  .slice(0, 3);
---

<MainLayout title={`${entry.data.title} - Blog`} description={entry.data.description}>
  <!-- Article Header -->
  <section class="py-12 px-4 bg-gradient-to-br from-blue-50 to-purple-50 dark:from-slate-950 dark:to-purple-950 border-b border-slate-200 dark:border-slate-800">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6">
        <a href="/blog" class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-2">
          <span>←</span> Back to Blog
        </a>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{entry.data.title}</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">{entry.data.description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-600 dark:text-slate-400 border-t border-slate-200 dark:border-slate-700 pt-4">
        <time>
          {new Date(entry.data.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span>•</span>
        <span>{entry.data.author}</span>
        {entry.data.image && (
          <>
            <span>•</span>
            <img src={entry.data.image} alt={entry.data.title} class="w-12 h-12 rounded-full object-cover" />
          </>
        )}
      </div>
    </div>
  </section>

  <!-- Article Image -->
  {entry.data.image && (
    <section class="py-8 px-4">
      <div class="max-w-3xl mx-auto">
        <img src={entry.data.image} alt={entry.data.title} class="w-full rounded-lg shadow-lg" />
      </div>
    </section>
  )}

  <!-- Article Content -->
  <section class="py-12 px-4">
    <article class="max-w-3xl mx-auto prose dark:prose-invert prose-sm md:prose-base">
      <Content />
    </article>
  </section>

  <!-- Tags -->
  <section class="py-8 px-4 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-3xl mx-auto">
      <h3 class="font-semibold mb-4">Tags</h3>
      <div class="flex flex-wrap gap-2">
        {entry.data.tags.map((tag: string) => (
          <span key={tag} class="px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 px-4 bg-slate-50 dark:bg-slate-900/50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8">Related Articles</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a
              key={post.slug}
              href={`/blog/${post.slug}`}
              class="group p-6 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-all"
            >
              <time class="text-sm text-slate-500 dark:text-slate-400">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <h3 class="text-lg font-bold mt-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 mt-2 line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</MainLayout>

<style is:global>
  /* Typography for prose content */
  .prose {
    @apply text-slate-700 dark:text-slate-300;
  }

  .prose h2 {
    @apply text-2xl font-bold mt-8 mb-4 text-slate-900 dark:text-white;
  }

  .prose h3 {
    @apply text-xl font-bold mt-6 mb-3 text-slate-900 dark:text-white;
  }

  .prose p {
    @apply mb-4 leading-relaxed;
  }

  .prose ul,
  .prose ol {
    @apply mb-4 ml-6;
  }

  .prose li {
    @apply mb-2;
  }

  .prose code {
    @apply bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded text-sm font-mono text-blue-600 dark:text-blue-400;
  }

  .prose pre {
    @apply bg-slate-900 dark:bg-slate-950 text-slate-100 p-4 rounded-lg overflow-x-auto mb-4;
  }

  .prose pre code {
    @apply bg-transparent p-0 text-slate-100;
  }

  .prose blockquote {
    @apply border-l-4 border-blue-500 pl-4 italic text-slate-600 dark:text-slate-400 my-4;
  }

  .prose a {
    @apply text-blue-600 dark:text-blue-400 hover:underline;
  }
</style>
