---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import { ProjectCard } from '../components/ui/ProjectCard.jsx';

const projects = [
  {
    title: 'E-Commerce Platform',
    description: 'Full-stack e-commerce solution with product catalog, shopping cart, and payment integration using Stripe.',
    tags: ['React', 'Node.js', 'PostgreSQL', 'Tailwind CSS'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1557821552-17105176677c?w=500&h=300&fit=crop',
  },
  {
    title: 'Task Management App',
    description: 'Real-time collaborative task management app with team features, notifications, and progress tracking.',
    tags: ['Vue 3', 'Firebase', 'Tailwind CSS'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=500&h=300&fit=crop',
  },
  {
    title: 'Analytics Dashboard',
    description: 'Interactive dashboard for real-time data visualization with charts, filters, and custom reports.',
    tags: ['React', 'Chart.js', 'Express', 'MongoDB'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=500&h=300&fit=crop',
  },
  {
    title: 'Weather App',
    description: 'Beautiful weather application with real-time data, forecasts, and multiple location support.',
    tags: ['React', 'Weather API', 'Mapbox', 'Vite'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1563183897-5f6c0e7b7e5d?w=500&h=300&fit=crop',
  },
  {
    title: 'Social Media Feed',
    description: 'Dynamic social media feed with infinite scroll, likes, comments, and real-time updates using WebSockets.',
    tags: ['Next.js', 'TypeScript', 'Prisma', 'Tailwind CSS'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1611532736579-6b16e2b50449?w=500&h=300&fit=crop',
  },
  {
    title: 'Portfolio Website',
    description: 'Modern, responsive portfolio website with dark mode, animations, and optimized for GitHub Pages.',
    tags: ['Astro', 'React', 'Tailwind CSS', 'Framer Motion'],
    link: 'https://example.com',
    github: 'https://github.com',
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=300&fit=crop',
  },
];
---

<MainLayout title="Projects - Manisha's Portfolio" description="View my portfolio projects and work">
  <PageHeader
    title="My Projects"
    description="A showcase of my recent work, side projects, and contributions to open source."
  />

  <!-- Projects Grid -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <ProjectCard
            key={project.title}
            client:load
            title={project.title}
            description={project.description}
            image={project.image}
            tags={project.tags}
            link={project.link}
            github={project.github}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6 text-gradient">Interested in working together?</h2>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-8">
        I'm always open to new projects and collaborations. Let's create something amazing!
      </p>
      <a href="#contact" class="btn-primary">Get In Touch</a>
    </div>
  </section>a
        href="#contact"
        class="inline-block px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-colors"
      >
        Get In Touch
      </a>
    </div>
  </section>
</MainLayout>
